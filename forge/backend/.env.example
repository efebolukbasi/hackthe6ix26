# Copy to .env and fill in what you have. Everything degrades gracefully.

# ElevenLabs — agent voice. Without it the frontend falls back to browser TTS.
ELEVENLABS_API_KEY=
# Optional: override the voice (default is Adam)
ELEVENLABS_VOICE_ID=

# Anthropic API key — fastest brain path. Without it the backend shells out to
# the local `claude` CLI (Claude Code login), which also works.
ANTHROPIC_API_KEY=

# Repo the agent should "know". Defaults to this git repo (self-explaining demo).
# REPO_PATH takes a local path; GITHUB_REPO takes a URL (shallow-cloned on boot).
REPO_PATH=
GITHUB_REPO=

# GitHub personal access token. Keep it on the backend; it needs repository
# contents read access and Issues write access.
GITHUB_TOKEN=

# Models (aliases used for the claude CLI; full ids used for the API)
FORGE_MODEL=sonnet
FORGE_LISTEN_MODEL=haiku

PORT=5180

# Optional locally, required for a public deployment. Share the deployed URL as
# https://your-app.example/#token=<this value> so the token stays out of server logs.
FORGE_ACCESS_TOKEN=
