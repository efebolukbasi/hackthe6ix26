# Copy to .env and fill in what you have. Everything degrades gracefully.

# ElevenLabs — agent voice. Without it the frontend falls back to browser TTS.
ELEVENLABS_API_KEY=
# Optional: override Forge's default ElevenLabs voice
ELEVENLABS_VOICE_ID=

# Anthropic API key — required for Forge's brain.
ANTHROPIC_API_KEY=

# Optional fixed repo. Left empty, the meeting starts WITHOUT a repository and
# participants sign in with GitHub to pick one from the dropdown.
# REPO_PATH takes a local path; GITHUB_REPO takes a URL (shallow-cloned on boot).
REPO_PATH=
GITHUB_REPO=

# "Sign in with GitHub" for meeting participants (OAuth device flow).
# Create an OAuth App (github.com/settings/developers), tick "Enable Device
# Flow" in its settings, and put its Client ID here. No secret needed.
GITHUB_OAUTH_CLIENT_ID=

# Optional deployment-wide fallback: a GitHub personal access token. Only used
# when the active repo wasn't loaded through a participant sign-in. Needs
# repository contents read access and Issues write access.
GITHUB_TOKEN=

PORT=5180

# Optional locally, required for a public deployment. Share the deployed URL as
# https://your-app.example/#token=<this value> so the token stays out of server logs.
FORGE_ACCESS_TOKEN=
