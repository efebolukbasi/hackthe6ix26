# Copy to .env and fill in what you have. Everything degrades gracefully.

# ElevenLabs — agent voice. Without it the frontend falls back to browser TTS.
ELEVENLABS_API_KEY=
# Optional: override the voice (default is Adam)
ELEVENLABS_VOICE_ID=

# Anthropic API key — fastest brain path. Without it the backend shells out to
# the local `claude` CLI (Claude Code login), which also works.
ANTHROPIC_API_KEY=

# Repo the agent should "know". Defaults to this git repo (self-explaining demo).
# REPO_PATH takes a local path; GITHUB_REPO takes a URL (shallow-cloned on boot).
REPO_PATH=
GITHUB_REPO=

# GitHub App sign-in (recommended). Create a GitHub App, make it public, and
# grant Contents: read and Issues: read/write. Its callback URL must be
# https://your-service.onrender.com/api/github/callback. These secrets stay on
# the server; each user authorizes with their own GitHub account in the browser.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Optional when the service URL cannot be inferred (must exactly match GitHub).
GITHUB_APP_CALLBACK_URL=

# Fallback for fixed deployments or local development. It is not required when
# GitHub App sign-in is configured. It needs access to the active repository
# and Issues: write. A local `gh` CLI login is also detected.
GITHUB_TOKEN=

# Models (aliases used for the claude CLI; full ids used for the API)
FORGE_MODEL=sonnet
FORGE_LISTEN_MODEL=haiku

PORT=5180

# Optional locally, required for a public deployment. Share the deployed URL as
# https://your-app.example/#token=<this value> so the token stays out of server logs.
FORGE_ACCESS_TOKEN=
